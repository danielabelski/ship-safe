# ── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL="postgresql://localhost:5432/shipsafe?schema=public" # ship-safe-ignore

# ── Auth.js ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# GitHub OAuth — https://github.com/settings/developers
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_ID="your-google-client-id"
GOOGLE_SECRET="your-google-client-secret"

# ── Stripe (subscription billing) ────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Notifications ─────────────────────────────────────────
# Resend — https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Ship Safe <noreply@shipsafe.dev>"

# ── GitHub App (optional) ────────────────────────────────
# Create at https://github.com/settings/apps
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_WEBHOOK_SECRET=""

# ── App ───────────────────────────────────────────────────
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="https://shipsafecli.com"

# \u2500\u2500 Hermes Agent Studio (Phase 2 \u2014 VPS deployment) \u2500\u2500\u2500\u2500\u2500\u2500\u2500
ORCHESTRATOR_URL="http://127.0.0.1:4099"
ORCHESTRATOR_SECRET="your-strong-random-secret"
VPS_SUBDOMAIN_BASE="agents.shipsafecli.com"
NEXT_PUBLIC_SUBDOMAIN_BASE="agents.shipsafecli.com"

# ── Cron (required on Vercel) ─────────────────────────────
# Set automatically by Vercel, or generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# ── Agent runtime ─────────────────────────────────────────
# Max ms to wait for an agent response (default: 300000 = 5 min)
AGENT_TIMEOUT_MS="300000"
